# Auto normalize line endings for all files
* text=auto

# JavaScript/Node files
*.js text eol=lf
*.mjs text eol=lf
*.cjs text eol=lf
*.json text eol=lf
*.ts text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows batch
*.bat text eol=crlf
*.cmd text eol=crlf

# Markdown
*.md text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
